.env
__pycache__/

# Machine-local project config (keep .claude/memory/ tracked)
.claude/settings.local.json

# Ignore all skills, whitelist ours
claude/skills/*
!claude/skills/annotate/
!claude/skills/build/
!claude/skills/clean-code/
!claude/skills/commit/
!claude/skills/deploy/
!claude/skills/document-data-flow/
!claude/skills/documentation/
!claude/skills/github-pages/
!claude/skills/github-status/
claude/skills/github-status/config/
!claude/skills/memo/
!claude/skills/move-project/
!claude/skills/plan-ralphex/
!claude/skills/plannotator-update/
!claude/skills/pr-create/
!claude/skills/pr-merge/
!claude/skills/pr-prepare/
!claude/skills/publish-chrome-extension/
claude/skills/publish-chrome-extension/config/
!claude/skills/reflect/
!claude/skills/release/
!claude/skills/reset/
!claude/skills/shared/
!claude/skills/skill/
